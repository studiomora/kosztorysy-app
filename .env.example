# Рядок підключення до Neon Postgres (Pooled connection).
# Отримати: https://console.neon.tech -> твій проєкт -> Connection Details -> Pooled connection
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Простий спільний пароль для доступу до всього застосунку.
# Залиш порожнім, щоб вимкнути захист паролем.
APP_PASSWORD="change-me"
